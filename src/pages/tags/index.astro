---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MinimalFooter from '../../components/MinimalFooter.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).filter(p => !p.data.draft);

const tagMap = new Map<string, number>();
allPosts.forEach(post => {
  post.data.tags.forEach(tag => {
    tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
  });
});

const tags = [...tagMap.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout
  title="Topics — China AI Digest"
  description="Browse all topics covered on China AI Digest — AI policy, research, companies, and more."
>
  <div class="container">
    <section class="page-header">
      <h1 class="page-title">TOPICS</h1>
    </section>

    <div class="tags-list">
      {tags.map(([tag, count]) => (
        <a
          href={`/tags/${tag.toLowerCase().replace(/\s+/g, '-')}`}
          class="tag-pill"
        >
          {tag.toUpperCase()} ({count})
        </a>
      ))}
    </div>
  </div>

  <MinimalFooter slot="footer" />
</BaseLayout>

<style>
  .page-header {
    margin-top: 64px;
    margin-bottom: 48px;
  }

  .page-title {
    font-family: var(--font-serif);
    font-size: 36px;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--text-primary);
  }

  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    padding-bottom: 80px;
  }

  .tag-pill {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 8px 24px;
    border: 1px solid black;
    color: var(--text-primary);
    text-decoration: none;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .tag-pill:hover {
    background: black;
    color: white;
  }

  @media (max-width: 767px) {
    .page-title {
      font-size: 28px;
    }

    .page-header {
      margin-top: 40px;
      margin-bottom: 32px;
    }
  }
</style>
