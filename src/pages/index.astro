---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import GhostButton from '../components/GhostButton.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const heroPost = allPosts.find(p => p.data.featured) ?? allPosts[0];
const remainingPosts = allPosts.filter(p => p.id !== heroPost.id);

const featuredPosts = remainingPosts.slice(0, 6);
const latestPosts = remainingPosts.slice(0, 8);
const bottomPosts = remainingPosts.slice(6, 10);
---

<BaseLayout
  title="ChinaAI — Stories that matter"
  description="ChinaAI is an editorial blog covering technology, design, culture, and travel."
  preloadImage={heroPost.data.heroImage}
>
  <!-- Hero Section -->
  <section class="hero-section container">
    <div class="hero-image-side">
      {heroPost.data.heroImage ? (
        <img
          src={heroPost.data.heroImage}
          alt={heroPost.data.title}
          loading="eager"
          fetchpriority="high"
          class="hero-img"
        />
      ) : (
        <div class="hero-img-placeholder"></div>
      )}
    </div>
    <div class="hero-content">
      {heroPost.data.category && (
        <span class="hero-category">{heroPost.data.category}</span>
      )}
      <h1 class="hero-title">
        <a href={`/blog/${heroPost.id}`}>{heroPost.data.title}</a>
      </h1>
      <p class="hero-excerpt">
        {heroPost.data.excerpt ?? heroPost.data.description}
      </p>
      <span class="hero-author">BY {heroPost.data.author ?? 'ChinaAI'}</span>
    </div>
  </section>

  <!-- Featured Grid -->
  <section class="container">
    <div class="featured-grid">
      {featuredPosts.map(post => (
        <ArticleCard post={post} />
      ))}
    </div>
  </section>

  <!-- Latest Posts Section -->
  <section class="container">
    <h2 class="section-title">LATEST POSTS</h2>
    <div class="latest-grid">
      {latestPosts.map(post => (
        <ArticleCard post={post} size="small" />
      ))}
    </div>
    <div class="button-center">
      <GhostButton href="/latest" text="VIEW ALL LATEST POSTS" />
    </div>
  </section>

  <!-- Bottom Grid -->
  {bottomPosts.length > 0 && (
    <section class="container">
      <div class="bottom-grid">
        {bottomPosts.map(post => (
          <ArticleCard post={post} size="large" />
        ))}
      </div>
    </section>
  )}

  <!-- Newsletter Strip -->
  <section class="newsletter-strip">
    <div class="container newsletter-inner">
      <div class="newsletter-text">
        <h2 class="newsletter-heading">Stay in the loop</h2>
        <p class="newsletter-sub">
          New stories on technology, design, culture, and travel — delivered when they matter.
        </p>
      </div>
      <div class="newsletter-form">
        <input
          type="email"
          placeholder="your@email.com"
          class="newsletter-input"
          aria-label="Email address"
        />
        <button type="button" class="newsletter-btn">Subscribe</button>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* Hero Section */
  .hero-section {
    display: grid;
    grid-template-columns: 60% 40%;
    min-height: 480px;
    align-items: center;
  }

  .hero-image-side {
    height: 100%;
    min-height: 480px;
    overflow: hidden;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-img-placeholder {
    width: 100%;
    height: 100%;
    min-height: 480px;
    background-color: var(--color-gray-100);
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-left: 48px;
  }

  .hero-category {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-secondary);
    margin-bottom: 8px;
    display: block;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: 48px;
    font-weight: 700;
    line-height: 1.1;
    color: var(--text-primary);
    margin-bottom: 16px;
  }

  .hero-title a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .hero-title a:hover {
    opacity: 0.8;
  }

  .hero-excerpt {
    font-family: var(--font-sans);
    font-size: 16px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-top: 0;
  }

  .hero-author {
    display: block;
    font-family: var(--font-sans);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-secondary);
    margin-top: 24px;
  }

  /* Featured Grid */
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-top: 64px;
  }

  /* Latest Posts Section */
  .section-title {
    text-align: center;
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-secondary);
    margin: 64px 0;
  }

  .latest-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .button-center {
    display: flex;
    justify-content: center;
    margin-top: 48px;
  }

  /* Bottom Grid */
  .bottom-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
    margin-top: 64px;
    margin-bottom: 64px;
  }

  /* Responsive */
  @media (max-width: 991px) {
    .hero-section {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .hero-image-side {
      min-height: 320px;
    }

    .hero-content {
      padding-left: 0;
      padding-top: 24px;
    }

    .featured-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .latest-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Newsletter Strip */
  .newsletter-strip {
    background-color: #111111;
    color: white;
    margin-top: 64px;
    padding: 64px 0;
  }

  .newsletter-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 48px;
  }

  .newsletter-heading {
    font-family: var(--font-serif);
    font-size: 30px;
    font-weight: 400;
    color: white;
    margin-bottom: 8px;
  }

  .newsletter-sub {
    font-family: var(--font-sans);
    font-size: 14px;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.6;
    max-width: 380px;
  }

  .newsletter-form {
    display: flex;
    flex-shrink: 0;
  }

  .newsletter-input {
    width: 260px;
    background: white;
    color: var(--text-primary);
    border: none;
    padding: 12px 16px;
    font-size: 14px;
    font-family: var(--font-sans);
    outline: none;
  }

  .newsletter-input::placeholder {
    color: var(--color-gray-500);
  }

  .newsletter-btn {
    background: white;
    color: black;
    border: none;
    padding: 12px 24px;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .newsletter-btn:hover {
    opacity: 0.85;
  }

  @media (max-width: 767px) {
    .hero-title {
      font-size: 32px;
    }

    .featured-grid {
      grid-template-columns: 1fr;
    }

    .latest-grid {
      grid-template-columns: 1fr;
    }

    .bottom-grid {
      grid-template-columns: 1fr;
    }

    .section-title {
      margin: 40px 0;
    }

    .featured-grid,
    .bottom-grid {
      margin-top: 40px;
    }

    .newsletter-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }

    .newsletter-form {
      width: 100%;
    }

    .newsletter-input {
      flex: 1;
      width: auto;
    }
  }
</style>
