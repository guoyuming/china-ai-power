---
import type { CollectionEntry } from 'astro:content';
import { readingTime } from '../utils/readingTime';

interface Props {
  post: CollectionEntry<'blog'>;
  size?: 'default' | 'small' | 'large';
}

const { post, size = 'default' } = Astro.props;
const { title, heroImage } = post.data;
const href = `/blog/${post.id}`;
const timeToRead = readingTime(post.body ?? '');
---

<a href={href} class={`article-card article-card--${size}`}>
  <article>
    <div class="card-image-wrapper">
      {heroImage ? (
        <img
          src={heroImage}
          alt={title}
          loading="lazy"
          class="card-image"
          transition:name={`hero-/blog/${post.id}`}
        />
      ) : (
        <div class="card-image-placeholder"></div>
      )}
    </div>
    <div class="card-content">
      <h3 class="card-title">{title}</h3>
      <div class="card-meta">
        <span class="card-reading-time">{timeToRead}</span>
      </div>
    </div>
  </article>
</a>

<style>
  .article-card {
    display: block;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .article-card article {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .card-image-wrapper {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    border-radius: 0;
  }

  .article-card--large .card-image-wrapper {
    aspect-ratio: 16 / 9;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .card-image-placeholder {
    width: 100%;
    height: 100%;
    background-color: var(--color-gray-100);
  }

  .article-card:hover .card-image {
    transform: scale(1.05);
  }

  .card-content {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 400;
    line-height: 1.2;
    color: var(--text-primary);
    margin: 0;
    transition: opacity 0.2s ease;
  }

  .article-card--small .card-title {
    font-size: 16px;
  }

  .article-card--large .card-title {
    font-size: 24px;
  }

  .article-card:hover .card-title {
    opacity: 0.7;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .card-reading-time {
    font-family: var(--font-sans);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-secondary);
  }
</style>
