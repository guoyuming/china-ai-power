---
// Search modal powered by Pagefind.
// Pagefind assets only exist after `npm run build`.
// In dev mode, a friendly message is shown instead.
---

<div
  id="search-modal"
  class="search-modal"
  aria-hidden="true"
  role="dialog"
  aria-label="Search"
>
  <div class="search-backdrop" id="search-backdrop"></div>
  <div class="search-panel">
    <div class="search-panel-header">
      <span class="search-panel-label">Search</span>
      <button class="search-close" id="search-close" aria-label="Close search">
        &#x2715;
      </button>
    </div>
    <div id="pagefind-ui-root"></div>
  </div>
</div>

<script>
  const modal = document.getElementById('search-modal');
  const backdrop = document.getElementById('search-backdrop');
  const closeBtn = document.getElementById('search-close');

  let initialized = false;

  async function openSearch() {
    if (!modal) return;
    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';

    if (!initialized) {
      initialized = true;
      try {
        const link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = '/pagefind/pagefind-ui.css';
        document.head.appendChild(link);

        // Load via script tag so Rollup doesn't try to bundle it at build time.
        // The file is generated by pagefind after `astro build`.
        await new Promise<void>((resolve, reject) => {
          const script = document.createElement('script');
          script.src = '/pagefind/pagefind-ui.js';
          script.onload = () => resolve();
          script.onerror = () => reject(new Error('pagefind script not found'));
          document.head.appendChild(script);
        });
        // @ts-ignore
        new PagefindUI({
          element: '#pagefind-ui-root',
          showImages: false,
          resetStyles: false,
          excerptLength: 15,
        });
      } catch {
        const root = document.getElementById('pagefind-ui-root');
        if (root) {
          root.innerHTML =
            '<p class="search-unavailable">Search is available after a production build.<br>Run <code>npm run build &amp;&amp; npm run preview</code>.</p>';
        }
      }
    }

    setTimeout(() => {
      const input = modal.querySelector<HTMLInputElement>('input[type="text"]');
      input?.focus();
    }, 80);
  }

  function closeSearch() {
    if (!modal) return;
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  document.getElementById('search-trigger')?.addEventListener('click', openSearch);
  closeBtn?.addEventListener('click', closeSearch);
  backdrop?.addEventListener('click', closeSearch);

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeSearch();
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      openSearch();
    }
  });
</script>

<style>
  .search-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9000;
  }

  .search-modal.is-open {
    display: block;
  }

  .search-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
  }

  .search-panel {
    position: absolute;
    top: 10vh;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 640px;
    background: white;
    padding: 24px;
    max-height: 80vh;
    overflow-y: auto;
  }

  .search-panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .search-panel-label {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-secondary);
  }

  .search-close {
    background: none;
    border: none;
    font-size: 18px;
    cursor: pointer;
    color: var(--text-secondary);
    padding: 4px 6px;
    line-height: 1;
    transition: color 0.2s ease;
  }

  .search-close:hover {
    color: var(--text-primary);
  }

  /* Pagefind UI style overrides */
  :global(#pagefind-ui-root) {
    --pagefind-ui-font: var(--font-sans);
  }

  :global(#pagefind-ui-root .pagefind-ui__search-input) {
    font-family: var(--font-sans) !important;
    font-size: 14px !important;
    border: 1px solid var(--color-gray-300) !important;
    border-radius: 0 !important;
    padding: 12px 16px !important;
    width: 100% !important;
    box-shadow: none !important;
  }

  :global(#pagefind-ui-root .pagefind-ui__search-input:focus) {
    border-color: var(--color-blue-400) !important;
    outline: none !important;
    box-shadow: none !important;
  }

  :global(#pagefind-ui-root .pagefind-ui__search-clear) {
    font-family: var(--font-sans) !important;
    border-radius: 0 !important;
  }

  :global(#pagefind-ui-root .pagefind-ui__result-link) {
    font-family: var(--font-serif) !important;
    color: var(--text-primary) !important;
  }

  :global(#pagefind-ui-root .pagefind-ui__result-excerpt) {
    font-family: var(--font-sans) !important;
    font-size: 13px !important;
    color: var(--text-secondary) !important;
  }

  .search-unavailable {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--text-secondary);
    padding: 16px 0;
    line-height: 1.6;
  }

  .search-unavailable code {
    font-family: monospace;
    background: var(--color-gray-100);
    padding: 2px 6px;
  }

  @media (max-width: 767px) {
    .search-panel {
      top: 0;
      left: 0;
      right: 0;
      transform: none;
      max-width: 100%;
      max-height: 100vh;
      border-radius: 0;
    }
  }
</style>
