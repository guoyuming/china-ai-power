---
import BaseLayout from './BaseLayout.astro';
import MinimalFooter from '../components/MinimalFooter.astro';
import Pagination from '../components/Pagination.astro';

interface Props {
  title: string;
  description: string;
  currentPage?: number;
  totalPages?: number;
  basePath?: string;
}

const {
  title,
  description,
  currentPage = 1,
  totalPages = 1,
  basePath = '/latest',
} = Astro.props;
---

<BaseLayout title={`${title} — ChinaAI`} description={description}>
  <div class="container">
    <section class="page-header">
      <h1 class="page-title">{title}</h1>
    </section>

    <div class="posts-grid">
      <slot />
    </div>

    <Pagination
      currentPage={currentPage}
      totalPages={totalPages}
      basePath={basePath}
    />
  </div>

  <MinimalFooter slot="footer" />
</BaseLayout>

<style>
  .page-header {
    margin-top: 64px;
    margin-bottom: 48px;
  }

  .page-title {
    font-family: var(--font-serif);
    font-size: 36px;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--text-primary);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  @media (max-width: 991px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 767px) {
    .page-title {
      font-size: 28px;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }

    .page-header {
      margin-top: 40px;
      margin-bottom: 32px;
    }
  }
</style>
